---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const issues = (await getCollection('newsletter')).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
  );
  return issues.map((issue, index) => ({
    params: { slug: issue.slug },
    props: { 
      issue,
      prev: issues[index + 1] ?? null,
      next: issues[index - 1] ?? null,
    },
  }));
}

const { issue, prev, next } = Astro.props;
const { Content } = await issue.render();
---
<Base title={`${issue.data.title} // Gaysex Solutions`}>

<nav class="breadcrumb">
  <a href="/">Home</a>
  <span>›</span>
  <a href="/newsletter">Newsletters</a>
  <span>›</span>
  <span class="crumb-current">{issue.data.title}</span>
</nav>

  <div class="post-header">
    <div class="post-date">{issue.data.date.toISOString().split('T')[0]}</div>
    <h1 class="post-title">{issue.data.title}</h1>
    <div class="post-excerpt">{issue.data.excerpt}</div>
  </div>

  {issue.data.thumbnail && (
    <div class="post-hero">
      <img src={issue.data.thumbnail} alt={issue.data.title} />
    </div>
  )}

  <div class="post-body">
    <Content />
  </div>
<div class="post-nav">
  <div class="post-nav-inner">
    {prev && (
      <a href={`/newsletter/${prev.slug}`} class="post-nav-prev">
        ◄ ...{prev.data.title.slice(-20)}
      </a>
    )}
    {!prev && <span></span>}
    <a href="/newsletter" class="post-nav-up">▲ Back to Newsletters</a>
    {next && (
      <a href={`/newsletter/${next.slug}`} class="post-nav-next">
        ...{next.data.title.slice(-35)} ►
      </a>
    )}
  </div>
</div>
</Base>

<style>
  .post-header {
    background: var(--panel);
    border: 1px solid var(--panel-border);
    box-shadow:
      inset 1px 1px 0 rgba(255,255,255,0.06),
      0 4px 20px rgba(0,0,0,0.5);
    padding: 20px;
    margin-bottom: 16px;
  }
  .post-date {
    font-size: 0.65rem;
    color: var(--white);
    letter-spacing: 0.2em;
    margin-bottom: 8px;
  }
  .post-title {
    font-size: 1.4rem;
    color: var(--gold);
    letter-spacing: 0.08em;
    text-shadow: 0 0 14px rgba(255,216,77,0.4);
    margin-bottom: 10px;
    line-height: 1.3;
    font-weight: normal;
  }
  .post-excerpt {
    font-size: 0.82rem;
    color: var(--white);
    line-height: 1.6;
    font-style: italic;
  }
  .post-hero {
    margin-bottom: 16px;
    border: 1px solid var(--panel-border);
  }
  .post-hero img {
    width: 100%;
    max-height: 400px;
    object-fit: cover;
    display: block;
  }
  .post-body {
    background: var(--panel);
    border: 1px solid var(--panel-border);
    box-shadow:
      inset 1px 1px 0 rgba(255,255,255,0.06),
      0 4px 20px rgba(0,0,0,0.5);
    padding: 24px;
    font-size: 1rem;
    line-height: 1.9;
    color: var(--white);
  }
  .post-body :global(h2) {
    color: var(--cyan);
    font-size: 1rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin: 24px 0 10px;
  }
  .post-body :global(h3) {
    color: var(--gold);
    font-size: 0.9rem;
    margin: 18px 0 8px;
  }
  .post-body :global(p) { margin-bottom: 14px; }
  .post-body :global(strong) { color: var(--gold); }
  .post-body :global(em) { color: var(--gold); }
  .post-body :global(hr) {
    border: none;
    border-top: 1px solid var(--panel-border);
    margin: 24px 0;
  }
.post-body :global(img) {
    max-width: 600px;
    width: 100%;
    height: auto;
    display: block;
    margin: 16px auto;
    border: 1px solid var(--panel-border);
  }
  .post-body :global(.img-grid) {
    display: grid;
    grid-template-columns: 1fr, 1fr;
    gap: 10px;
    margin: 16px 0;
	max-width: 500px;
  }
  .post-body :global(.img-grid img) {
    width: 100%;
    aspect-ratio: 1/1;
    object-fit: cover;
    margin: 0;
  }
  .post-body :global(.img-pair) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin: 16px 0;
  }
  .post-body :global(.img-pair img) {
    width: 100%;
    height: auto;
    margin: 0;
  }
  .post-body :global(img + em) {
    display: block;
    text-align: center;
    font-size: 0.9rem;
    color: var(--gold);
    letter-spacing: 0.1em;
    margin-top: 0px;
    margin-bottom: 14px;
  }
  .post-body :global(.img-grid em) {
    display: block;
    text-align: center;
    font-size: 0.9rem;
    color: var(--gold);
    letter-spacing: 0.1em;
    margin-bottom: 8px;
  }
@media (max-width: 900px) {
    .post-body :global(.img-grid) {
      grid-template-columns: 1fr;
      max-width: 200px;
    }
  }
  .post-body :global(.img-item) {
    text-align: center;
    margin-bottom: 16px;
  }
  .post-body :global(blockquote) {
    border-left: 3px solid var(--gold);
    background: rgba(255, 216, 77, 0.04);
    padding: 12px 16px;
    margin: 16px 0;
    color: var(--white);
  }
  .issue-nav {
    margin-top: 24px;
    padding: 12px 0;
    border-top: 1px solid var(--panel-border);
  }
  .issue-nav-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
  }
  .issue-nav-prev, .issue-nav-next {
    max-width: 25%;
	min-width:0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .issue-nav-next {
    text-align: right;
  }
  .issue-nav-up {
    color: var(--dim) !important;
    font-size: 0.7rem;
    flex-shrink: 0;
  }
</style>