---
// src/pages/photospheres/[slug].astro

import Base from '../../layouts/Base.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import Photospheres from '../../components/Photospheres.astro';

export async function getStaticPaths() {
  const entries = await getCollection('photospheres');
  return entries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'photospheres'>;
}

const { entry } = Astro.props;
const { title, location, date, cloudinaryId, cloudinaryCloud } = entry.data;

const fullUrl = `https://res.cloudinary.com/${cloudinaryCloud}/image/upload/f_auto,q_auto/${cloudinaryId}`;

const dateStr = date.toISOString().split('T')[0];
---

<Base title={`${title} // Gaysex Solutions`} description={location}>

  <nav class="breadcrumb">
    <a href="/">Home</a>
    <span>›</span>
    <a href="/photospheres">Photospheres</a>
    <span>›</span>
    <span class="crumb-current">{title}</span>
  </nav>

  <div class="post-header">
    <div class="post-date">{dateStr}</div>
    <h1 class="post-title">{title}</h1>
    <div class="post-excerpt">{location}</div>
  </div>

  <div class="viewer-wrap">
    <Photospheres imageUrl={fullUrl} title={title} />
  </div>

  <div class="post-nav">
    <a href="/photospheres">◄ Back to Photospheres</a>
  </div>

</Base>

<style>
  .post-header {
    background: var(--panel);
    border: 1px solid var(--panel-border);
    box-shadow:
      inset 1px 1px 0 rgba(255,255,255,0.06),
      0 4px 20px rgba(0,0,0,0.5);
    padding: 20px;
    margin-bottom: 16px;
  }
  .post-date {
    font-size: 0.65rem;
    color: var(--white);
    letter-spacing: 0.2em;
    margin-bottom: 8px;
  }
  .post-title {
    font-size: 1.4rem;
    color: var(--gold);
    letter-spacing: 0.08em;
    text-shadow: 0 0 14px rgba(255,216,77,0.4);
    margin-bottom: 10px;
    line-height: 1.3;
    font-weight: normal;
  }
  .post-excerpt {
    font-size: 0.82rem;
    color: var(--white);
    line-height: 1.6;
    font-style: italic;
  }

  .viewer-wrap {
    border: 1px solid var(--panel-border);
    box-shadow:
      inset 1px 1px 0 rgba(255,255,255,0.06),
      0 4px 20px rgba(0,0,0,0.5);
    margin-bottom: 16px;
    overflow: hidden;
  }

  .viewer-wrap > div {
    aspect-ratio: unset !important;
    height: clamp(320px, 60vh, 680px);
    border-radius: 0;
  }

  .post-nav {
    margin-top: 16px;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
  }
  .post-nav a {
    color: var(--cyan);
    text-decoration: none;
  }
  .post-nav a:hover {
    color: var(--gold);
  }
</style>