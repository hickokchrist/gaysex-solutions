---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const albums = (await getCollection('gallery')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---
<Base title="Gallery // Gaysex Solutions">

  <div class="page-heading">>> <strong>Gallery</strong></div>

  <div class="gallery-grid">
    {albums.map(album => (
      <a href={`/gallery/${album.slug}`} class="gallery-tile">
        <div class="tile-thumb">
          {album.data.thumbnail
            ? <img src={album.data.thumbnail} alt={album.data.title} />
            : <div class="tile-placeholder">// NO IMAGE</div>
          }
        </div>
        <div class="tile-label">
          <div class="tile-title">{album.data.title}</div>
          <div class="tile-date">{album.data.date.toISOString().split('T')[0]}</div>
        </div>
      </a>
    ))}
  </div>
<div class="post-nav">
  <a href="/">◄ Back to Home</a>
</div>

</Base>

<style>
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 12px;
  }

  .gallery-tile {
    display: flex;
    flex-direction: column;
    background: var(--panel);
    border: 1px solid var(--panel-border);
    box-shadow:
      inset 1px 1px 0 rgba(255,255,255,0.06),
      0 4px 20px rgba(0,0,0,0.5);
    text-decoration: none !important;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
    overflow: hidden;
  }
  .gallery-tile:hover {
    border-color: var(--cyan);
    box-shadow: 0 0 16px rgba(0,234,255,0.15);
    transform: translateY(-2px);
  }

  .tile-thumb {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: #000;
  }
  .tile-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  .gallery-tile:hover .tile-thumb img {
    transform: scale(1.05);
  }

  .tile-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.6rem;
    color: var(--dim);
    letter-spacing: 0.15em;
  }

  .tile-label {
    padding: 8px 10px;
    border-top: 1px solid var(--panel-border);
  }
  .tile-title {
    font-size: 0.78rem;
    color: var(--gold);
    letter-spacing: 0.06em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .tile-date {
    font-size: 0.6rem;
    color: var(--dim);
    letter-spacing: 0.15em;
    margin-top: 2px;
  }
</style>