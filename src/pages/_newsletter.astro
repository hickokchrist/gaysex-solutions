---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const issues = (await getCollection('newsletter')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---
<Base title="Newsletter // Gaysex Solutions" description="Christopher's newsletter, adapted from print to this digital medium.">

  <div class="page-heading">>> Newsletter</div>

  <div class="posts-grid">
    {issues.map(issue => (
      <a href={`/newsletter/${issue.slug}`} class="post-card">
        <div class="post-thumb">
          {issue.data.thumbnail
            ? <img src={issue.data.thumbnail} alt={issue.data.title} />
            : <div class="thumb-placeholder">// NO IMAGE</div>
          }
        </div>
        <div class="post-info">
          <div class="post-date">{issue.data.date.toISOString().split('T')[0]}</div>
          <div class="post-title">{issue.data.title}</div>
          <div class="post-excerpt">{issue.data.excerpt}</div>
        </div>
      </a>
    ))}
  </div>
<div class="post-nav">
  <a href="/">◄ Back to Home</a>
</div>

</Base>

<style>
  .posts-grid {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .post-card {
    display: flex;
    gap: 16px;
    background: var(--panel);
    border: 1px solid var(--panel-border);
    box-shadow:
      inset 1px 1px 0 rgba(255,255,255,0.06),
      0 4px 20px rgba(0,0,0,0.5);
    padding: 14px;
    text-decoration: none !important;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .post-card:hover {
    border-color: var(--cyan);
    box-shadow: 0 0 16px rgba(0,234,255,0.15);
  }
  .post-thumb {
    width: 120px;
    min-width: 120px;
    height: 80px;
    overflow: hidden;
    border: 1px solid var(--panel-border);
    background: #000;
  }
  .post-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .thumb-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.6rem;
    color: var(--dim);
    letter-spacing: 0.15em;
  }
  .post-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .post-date {
    font-size: 0.65rem;
    color: var(--dim);
    letter-spacing: 0.2em;
  }
  .post-title {
    font-size: 0.95rem;
    color: var(--gold);
    letter-spacing: 0.08em;
  }
