---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = (await getCollection('blog')).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
  );
  return posts.map((post, index) => ({
    params: { slug: post.slug },
    props: { 
      post,
      prev: posts[index + 1] ?? null,
      next: posts[index - 1] ?? null,
    },
  }));
}

const { post, prev, next } = Astro.props;
const { Content } = await post.render();
---
<Base title={`${post.data.title} // Gaysex Solutions`} description={post.data.excerpt}
  image={post.data.thumbnail}>

<nav class="breadcrumb">
  <a href="/">Home</a>
  <span>›</span>
  <a href="/blog">Blog</a>
  <span>›</span>
  <span class="crumb-current">{post.data.title}</span>
</nav>

  <div class="post-header">
    <div class="post-date">{post.data.date.toISOString().split('T')[0]}</div>
    <h1 class="post-title">{post.data.title}</h1>
    <div class="post-excerpt">{post.data.excerpt}</div>
  </div>

  {post.data.thumbnail && (
    <div class="post-hero">
      <img src={post.data.thumbnail} alt={post.data.title} />
    </div>
  )}

  <div class="post-body">
    <Content />
  </div>

  {post.data.tags && post.data.tags.length > 0 && (
    <div class="post-tags-block">
      <span class="tags-label">// TAGS:</span>
      {post.data.tags.map(tag => (
        <span class="post-tag">{tag}</span>
      ))}
    </div>
  )}

  <div class="post-nav">
    <div class="post-nav-inner">
      {prev && (
        <a href={`/blog/${prev.slug}`} class="post-nav-prev">
          ◄ {prev.data.title}
        </a>
      )}
      {!prev && <span></span>}
      <a href="/blog" class="post-nav-up">▲ Back to Blog</a>
      {next && (
        <a href={`/blog/${next.slug}`} class="post-nav-next">
          {next.data.title} ►
        </a>
      )}
    </div>
  </div>

</Base>

<style>
  .post-header {
    background: var(--panel);
    border: 1px solid var(--panel-border);
    box-shadow:
      inset 1px 1px 0 rgba(255,255,255,0.06),
      0 4px 20px rgba(0,0,0,0.5);
    padding: 20px;
    margin-bottom: 16px;
  }
  .post-date {
    font-size: 0.65rem;
    color: var(--white);
    letter-spacing: 0.2em;
    margin-bottom: 8px;
  }
  .post-title {
    font-size: 1.4rem;
    color: var(--gold);
    letter-spacing: 0.08em;
    text-shadow: 0 0 14px rgba(255,216,77,0.4);
    margin-bottom: 10px;
    line-height: 1.3;
    font-weight: normal;
  }
  .post-excerpt {
    font-size: 0.85rem;
    color: var(--white);
    line-height: 1.6;
    font-style: italic;
  }
  .post-hero {
    margin-bottom: 16px;
    border: 1px solid var(--panel-border);
  }
  .post-hero img {
    width: 100%;
    max-height: 400px;
    object-fit: cover;
    display: block;
  }
  .post-body {
    background: var(--panel);
    border: 1px solid var(--panel-border);
    box-shadow:
      inset 1px 1px 0 rgba(255,255,255,0.06),
      0 4px 20px rgba(0,0,0,0.5);
    padding: 24px;
    font-size: 1rem;
    line-height: 1.9;
    color: var(--white);
  }
  .post-body :global(h2) {
    color: var(--cyan);
    font-size: 1rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin: 24px 0 10px;
  }
  .post-body :global(h3) {
    color: var(--gold);
    font-size: 0.9rem;
    margin: 18px 0 8px;
  }
  .post-body :global(p) { margin-bottom: 14px; }
  .post-body :global(strong) { color: var(--gold); }
  .post-body :global(em) { color: var(--gold); }
  .post-body :global(hr) {
    border: none;
    border-top: 1px solid var(--panel-border);
    margin: 24px 0;
  }
  .post-body :global(img) {
    max-width: 100%;
    height: auto;
    display: block;
    margin: 16px auto;
    border: 1px solid var(--panel-border);
  }
  .post-body :global(.img-item p) {
    text-align: center;
    margin-bottom: 0;
  }
  .post-tags-block {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
    margin-top: 16px;
    padding: 12px 16px;
    background: var(--panel);
    border: 1px solid var(--panel-border);
  }
  .tags-label {
    font-size: 0.65rem;
    color: var(--dim);
    letter-spacing: 0.2em;
    margin-right: 4px;
  }
  .post-tag {
    font-size: 0.65rem;
    color: var(--cyan);
    border: 1px solid var(--panel-border);
    padding: 3px 9px;
    letter-spacing: 0.1em;
    font-family: 'Courier New', monospace;
  }
  .post-nav {
    margin-top: 24px;
    padding: 12px 0;
    border-top: 1px solid var(--panel-border);
  }
  .post-nav-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
  }
  .post-nav-prev, .post-nav-next {
    max-width: 25%;
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .post-nav-next {
    text-align: right;
  }
  .post-nav-up {
    color: var(--dim) !important;
    font-size: 0.7rem;
    flex-shrink: 0;
  }
  .post-body :global(img + em) {
    display: block;
    text-align: center;
    font-size: 0.9rem;
    color: var(--gold);
    letter-spacing: 0.1em;
    margin-top: 0px;
    margin-bottom: 14px;
  }
  .post-body :global(.img-grid em) {
    display: block;
    text-align: center;
    font-size: 0.9rem;
    color: var(--gold);
    letter-spacing: 0.1em;
    margin-bottom: 8px;
  }
</style>
