---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---
<Base title={`${post.data.title} // Gaysex Solutions`}>

  <div class="post-header">
    <div class="post-date">{post.data.date.toISOString().split('T')[0]}</div>
    <h1 class="post-title">{post.data.title}</h1>
    <div class="post-excerpt">{post.data.excerpt}</div>
  </div>

  {post.data.thumbnail && (
    <div class="post-hero">
      <img src={post.data.thumbnail} alt={post.data.title} />
    </div>
  )}

  <div class="post-body">
    <Content />
  </div>

</Base>

<style>
  .post-header {
    background: var(--panel);
    border: 1px solid var(--panel-border);
    box-shadow:
      inset 1px 1px 0 rgba(255,255,255,0.06),
      0 4px 20px rgba(0,0,0,0.5);
    padding: 20px;
    margin-bottom: 16px;
  }
  .post-date {
    font-size: 0.65rem;
    color: var(--dim);
    letter-spacing: 0.2em;
    margin-bottom: 8px;
  }
  .post-title {
    font-size: 1.4rem;
    color: var(--gold);
    letter-spacing: 0.08em;
    text-shadow: 0 0 14px rgba(255,216,77,0.4);
    margin-bottom: 10px;
    line-height: 1.3;
    font-weight: normal;
  }
  .post-excerpt {
    font-size: 0.82rem;
    color: var(--dim);
    line-height: 1.6;
    font-style: italic;
  }
  .post-hero {
    margin-bottom: 16px;
    border: 1px solid var(--panel-border);
  }
  .post-hero img {
    width: 100%;
    max-height: 400px;
    object-fit: cover;
    display: block;
  }
  .post-body {
    background: var(--panel);
    border: 1px solid var(--panel-border);
    box-shadow:
      inset 1px 1px 0 rgba(255,255,255,0.06),
      0 4px 20px rgba(0,0,0,0.5);
    padding: 24px;
    font-size: 0.85rem;
    line-height: 1.9;
    color: var(--white);
  }
  .post-body :global(h2) {
    color: var(--cyan);
    font-size: 1rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin: 24px 0 10px;
  }
  .post-body :global(h3) {
    color: var(--gold);
    font-size: 0.9rem;
    margin: 18px 0 8px;
  }
  .post-body :global(p) { margin-bottom: 14px; }
  .post-body :global(strong) { color: var(--gold); }
  .post-body :global(em) { color: var(--dim); }
  .post-body :global(hr) {
    border: none;
    border-top: 1px solid var(--panel-border);
    margin: 24px 0;
  }
</style>