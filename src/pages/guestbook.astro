---
import Base from '../layouts/Base.astro';
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
---
<Base title="Guestbook // Gaysex Solutions" description="Sign Christopher's guestbook and leave a message for the cosmos.">

  <div class="page-heading">>> Guestbook</div>

  <div class="info-block">
    <p style="color:var(--dim);font-size:0.75rem">Sign my guestbook! Entries are visible to all visitors.</p>
    <br>
    <div class="guestbook-form">
      <input type="text" id="gb-name" placeholder="Your name / handle" maxlength="40" />
      <input type="text" id="gb-planet" placeholder="Your planet of origin" maxlength="40" />
      <textarea id="gb-msg" placeholder="Leave a message for the cosmos..." maxlength="500"></textarea>
	  <input type="text" id="gb-honey" name="website" autocomplete="off" tabindex="-1" aria-hidden="true" style="opacity:0;position:absolute;left:-999px;height:0;width:0;" />
      <button class="btn" id="gb-submit">&#9654; Sign It</button>
      <div id="gb-status"></div>
    </div>
  </div>

  <div id="gb-entries"></div>

</Base>

<style>
  .guestbook-form {
    display: flex;
    flex-direction: column;
    gap: 10px;
    max-width: 500px;
  }
  .guestbook-form input,
  .guestbook-form textarea {
    background: #000814;
    border: 1px solid var(--panel-border);
    color: var(--white);
    font-family: 'Courier New', monospace;
    font-size: 0.8rem;
    padding: 8px 10px;
    outline: none;
    transition: border-color 0.2s;
  }
  .guestbook-form input:focus,
  .guestbook-form textarea:focus { border-color: var(--cyan); }
  .guestbook-form textarea { height: 90px; resize: vertical; }
  #gb-status {
    font-size: 0.75rem;
    letter-spacing: 0.1em;
  }
  :global(.entry-card) {
    background: var(--panel);
    border: 1px solid var(--panel-border);
    box-shadow:
      inset 1px 1px 0 rgba(255,255,255,0.06),
      0 4px 20px rgba(0,0,0,0.5);
    padding: 7px 9px;
    margin-bottom: 10px;
    max-width: 500px;
  }
  :global(.entry-meta) {
    font-size: 0.8rem;
    color: var(--cyan);
    margin-bottom: 6px;
  }
  :global(.entry-meta b) { color: var(--gold); font-size:.95rem; }
  :global(.entry-meta span) { color: var(--dim); margin-left: 10px; }
  :global(.entry-msg) {
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--white);
  }
  :global(.pagination) {
    display: flex;
    gap: 6px;
    margin-top: 20px;
    flex-wrap: wrap;
    align-items: center;
  }
  :global(.page-btn) {
    background: var(--panel);
    border: 1px solid var(--panel-border);
    color: var(--cyan);
    font-family: 'Courier New', monospace;
    font-size: 0.75rem;
    padding: 4px 10px;
    cursor: pointer;
    letter-spacing: 0.1em;
    transition: border-color 0.2s, color 0.2s;
  }
  :global(.page-btn:hover) {
    border-color: var(--cyan);
    color: var(--gold);
  }
  :global(.page-btn.active) {
    border-color: var(--gold);
    color: var(--gold);
  }
  :global(.page-ellipsis) {
    color: var(--dim);
    font-size: 0.75rem;
    padding: 4px 4px;
    font-family: 'Courier New', monospace;
  }
</style>

<script is:inline set:html={`window.__GB_URL__ = '${supabaseUrl}'; window.__GB_KEY__ = '${supabaseKey}';`}></script>

<script is:inline src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>

<script is:inline>
  const db = window.supabase.createClient(window.__GB_URL__, window.__GB_KEY__);

  const PER_PAGE = 10;
  let currentPage = 1;
  let totalCount = 0;

  async function loadEntries(page) {
    page = page || 1;
    currentPage = page;
    const from = (page - 1) * PER_PAGE;
    const to = from + PER_PAGE - 1;

    const { data, error, count } = await db
      .from('guestbook')
      .select('*', { count: 'exact' })
      .order('created_at', { ascending: false })
      .range(from, to);

    const container = document.getElementById('gb-entries');

    if (error || !data.length) {
      container.innerHTML = '<div style="color:var(--dim);font-size:0.75rem;padding:10px">No entries yet. Be the first!</div>';
      return;
    }

    totalCount = count;
    const totalPages = Math.ceil(totalCount / PER_PAGE);

    container.innerHTML = data.map(function(e) {
      return '<div class="entry-card"><div class="entry-meta">&#9733; <b>' + esc(e.name) + '</b> from <i>' + esc(e.planet) + '</i><span>' + e.created_at.split('T')[0] + '</span></div><div class="entry-msg">' + esc(e.message) + '</div></div>';
    }).join('') + renderPagination(currentPage, totalPages);
  }

  function renderPagination(current, total) {
    if (total <= 1) return '';

    const MAX_VISIBLE = 5;
    var pages = [];
    pages.push(1);

    var start = Math.max(2, current - 1);
    var end = Math.min(total - 1, current + 1);

    while (end - start < MAX_VISIBLE - 3 && (start > 2 || end < total - 1)) {
      if (start > 2) start--;
      if (end < total - 1) end++;
    }

    if (start > 2) pages.push('...');
    for (var i = start; i <= end; i++) pages.push(i);
    if (end < total - 1) pages.push('...');
    if (total > 1) pages.push(total);

    var buttons = pages.map(function(p) {
      if (p === '...') return '<span class="page-ellipsis">...</span>';
      return '<button class="page-btn' + (p === current ? ' active' : '') + '" data-page="' + p + '">' + p + '</button>';
    }).join('');

    return '<div class="pagination">' + buttons + '</div>';
  }

  document.getElementById('gb-entries').addEventListener('click', function(e) {
    if (e.target.matches('.page-btn')) {
      var page = parseInt(e.target.dataset.page);
      loadEntries(page);
      document.getElementById('gb-entries').scrollIntoView({ behavior: 'smooth' });
    }
  });

  document.getElementById('gb-submit').addEventListener('click', async function() {
    var name    = document.getElementById('gb-name').value.trim() || 'Anonymous';
    var planet  = document.getElementById('gb-planet').value.trim() || 'Earth';
    var message = document.getElementById('gb-msg').value.trim();
    var status  = document.getElementById('gb-status');

    if (!message) {
      status.style.color = 'var(--red)';
	  if (document.getElementById('gb-honey').value) return;
      status.textContent = '>> Please write a message first.';
      return;
    }

    status.style.color = 'var(--dim)';
    status.textContent = '>> Transmitting...';

let ipData = {};
    try {
      const ipRes = await fetch('https://ipapi.co/json/');
      ipData = await ipRes.json();
    } catch(e) {}

    const { error } = await db
      .from('guestbook')
      .insert([{
        name: name,
        planet: planet,
        message: message,
        user_agent: navigator.userAgent,
        language: navigator.language,
        screen: screen.width + 'x' + screen.height,
        timezone: Intl.DateTimeFormat().resolvedOptions().timeZone,
        platform: navigator.platform,
        cpu: navigator.hardwareConcurrency || null,
        memory: navigator.deviceMemory ? navigator.deviceMemory + 'GB' : null,
        touch: navigator.maxTouchPoints || null,
        color_depth: screen.colorDepth || null,
        ip_address: ipData.ip || null,
        city: ipData.city || null,
        region: ipData.region || null,
        country: ipData.country_name || null,
        isp: ipData.org || null,
        latitude: ipData.latitude || null,
        longitude: ipData.longitude || null
      }]);

    if (error) {
      status.style.color = 'var(--red)';
      status.textContent = '>> ' + error.message;
      return;
    }

    status.style.color = 'var(--green)';
    status.textContent = '>> Entry logged. Welcome to the cosmos!';
    document.getElementById('gb-name').value = '';
    document.getElementById('gb-planet').value = '';
    document.getElementById('gb-msg').value = '';
    loadEntries(1);
  });

  function esc(s) {
    return String(s)
      .replace(/&/g,'&amp;')
      .replace(/</g,'&lt;')
      .replace(/>/g,'&gt;')
      .replace(/"/g,'&quot;');
  }

  loadEntries(1);
</script>