---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const allTags = [...new Set(posts.flatMap(p => p.data.tags ?? []))].sort();
---
<Base title="Blog // Gaysex Solutions" description="Blog of minor events and musings.">

  <div class="page-heading">>> Blog</div>

  <div class="posts-grid" id="posts-grid">
    {posts.map(post => (
      <a
        href={`/blog/${post.slug}`}
        class="post-card"
        data-tags={JSON.stringify(post.data.tags ?? [])}
      >
        <div class="post-thumb">
          {post.data.thumbnail
            ? <img src={post.data.thumbnail} alt={post.data.title} />
            : <div class="thumb-placeholder">// NO IMAGE</div>
          }
        </div>
        <div class="post-info">
          <div class="post-date">{post.data.date.toISOString().split('T')[0]}</div>
          <div class="post-title">{post.data.title}</div>
          <div class="post-excerpt">{post.data.excerpt}</div>
        </div>
      </a>
    ))}
  </div>

  <div id="pagination-container"></div>

  {allTags.length > 0 && (
    <div class="tag-section">
      <hr class="tag-divider" />
      <div class="tag-filter" id="tag-filter">
        <span class="tag-label">// FILTER BY TAG:</span>
        {allTags.map(tag => (
          <button class="tag-btn" data-tag={tag}>{tag}</button>
        ))}
        <button class="tag-btn tag-clear" id="tag-clear">✕ clear</button>
      </div>
    </div>
  )}

  <div class="post-nav">
    <a href="/">◄ Back to Home</a>
  </div>

</Base>

<style>
  .posts-grid {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .post-card {
    display: flex;
    gap: 16px;
    background: var(--panel);
    border: 1px solid var(--panel-border);
    box-shadow:
      inset 1px 1px 0 rgba(255,255,255,0.06),
      0 4px 20px rgba(0,0,0,0.5);
    padding: 14px;
    text-decoration: none !important;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .post-card:hover {
    border-color: var(--cyan);
    box-shadow: 0 0 16px rgba(0,234,255,0.15);
  }
  .post-card.hidden {
    display: none;
  }
  .post-thumb {
    width: 120px;
    min-width: 120px;
    height: 80px;
    overflow: hidden;
    border: 1px solid var(--panel-border);
    background: #000;
  }
  .post-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .thumb-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.6rem;
    color: var(--dim);
    letter-spacing: 0.15em;
  }
  .post-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .post-date {
    font-size: 0.65rem;
    color: var(--white);
    letter-spacing: 0.2em;
  }
  .post-title {
    font-size: 0.95rem;
    color: var(--gold);
    letter-spacing: 0.08em;
  }
  .post-excerpt {
    font-size: 0.82rem;
    color: var(--white);
    opacity: 0.9;
    line-height: 1.6;
  }
  #pagination-container {
    display: flex;
    gap: 6px;
    margin-top: 20px;
    flex-wrap: wrap;
    align-items: center;
  }
  .page-btn {
    background: var(--panel);
    border: 1px solid var(--panel-border);
    color: var(--cyan);
    font-family: 'Courier New', monospace;
    font-size: 0.75rem;
    padding: 4px 10px;
    cursor: pointer;
    letter-spacing: 0.1em;
    transition: border-color 0.2s, color 0.2s;
  }
  .page-btn:hover {
    border-color: var(--cyan);
    color: var(--gold);
  }
  .page-btn.active {
    border-color: var(--gold);
    color: var(--gold);
  }
  .page-ellipsis {
    color: var(--dim);
    font-size: 0.75rem;
    padding: 4px 4px;
    font-family: 'Courier New', monospace;
  }
  .tag-section {
    margin-top: 24px;
  }
  .tag-divider {
    border: none;
    border-top: 1px solid var(--panel-border);
    margin-bottom: 16px;
  }
  .tag-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
    margin-bottom: 20px;
  }
  .tag-label {
    font-size: 0.65rem;
    color: var(--dim);
    letter-spacing: 0.2em;
    margin-right: 4px;
  }
  .tag-btn {
    background: var(--panel);
    border: 1px solid var(--panel-border);
    color: var(--cyan);
    font-family: 'Courier New', monospace;
    font-size: 0.7rem;
    padding: 4px 10px;
    cursor: pointer;
    letter-spacing: 0.1em;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
  }
  .tag-btn:hover {
    border-color: var(--cyan);
    color: var(--gold);
  }
  .tag-btn.active {
    background: rgba(0,234,255,0.15);
    border-color: var(--cyan);
    color: var(--gold);
  }
  .tag-clear {
    color: var(--dim);
    border-color: transparent;
  }
  .tag-clear:hover {
    color: var(--red);
    border-color: var(--red);
  }
</style>

<script is:inline>
  var PER_PAGE = 6;
  var activeTags = new Set();
  var currentPage = 1;

  var allCards = Array.from(document.querySelectorAll('.post-card'));

  function getFilteredCards() {
    if (activeTags.size === 0) return allCards;
    return allCards.filter(function(card) {
      var cardTags = JSON.parse(card.dataset.tags || '[]');
      return Array.from(activeTags).every(function(t) { return cardTags.includes(t); });
    });
  }

  function renderPage(page) {
    currentPage = page;
    var filtered = getFilteredCards();
    var totalPages = Math.ceil(filtered.length / PER_PAGE);
    var start = (page - 1) * PER_PAGE;
    var end = start + PER_PAGE;

    allCards.forEach(function(card) { card.classList.add('hidden'); });
    filtered.slice(start, end).forEach(function(card) { card.classList.remove('hidden'); });

    renderPagination(page, totalPages);
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function renderPagination(current, total) {
    var container = document.getElementById('pagination-container');
    container.innerHTML = '';
    if (total <= 1) return;

    var MAX_VISIBLE = 5;
    var pages = [];
    pages.push(1);

    var start = Math.max(2, current - 1);
    var end = Math.min(total - 1, current + 1);

    while (end - start < MAX_VISIBLE - 3 && (start > 2 || end < total - 1)) {
      if (start > 2) start--;
      if (end < total - 1) end++;
    }

    if (start > 2) pages.push('...');
    for (var i = start; i <= end; i++) pages.push(i);
    if (end < total - 1) pages.push('...');
    if (total > 1) pages.push(total);

    pages.forEach(function(p) {
      if (p === '...') {
        var span = document.createElement('span');
        span.className = 'page-ellipsis';
        span.textContent = '...';
        container.appendChild(span);
      } else {
        var btn = document.createElement('button');
        btn.className = 'page-btn' + (p === current ? ' active' : '');
        btn.textContent = p;
        btn.addEventListener('click', function() { renderPage(p); });
        container.appendChild(btn);
      }
    });
  }

  // Tag filtering
  var tagBtns = document.querySelectorAll('.tag-btn:not(#tag-clear)');
  var clearBtn = document.getElementById('tag-clear');

  if (tagBtns.length) {
    tagBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        var tag = btn.dataset.tag;
        if (activeTags.has(tag)) {
          activeTags.delete(tag);
          btn.classList.remove('active');
        } else {
          activeTags.add(tag);
          btn.classList.add('active');
        }
        renderPage(1);
      });
    });

    clearBtn.addEventListener('click', function() {
      activeTags.clear();
      tagBtns.forEach(function(b) { b.classList.remove('active'); });
      renderPage(1);
    });
  }

  renderPage(1);
</script>
